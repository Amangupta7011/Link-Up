{
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_KEY": "base64:9eJ4n8hP8L7M0HkI8LwE1E7F2T3W2T3W2T3W2T3W2T3=",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "CACHE_STORE": "array",
        "QUEU_CONNECTION": "sync",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    }
}