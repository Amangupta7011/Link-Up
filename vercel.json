{
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0",
            "includeFiles": "{app,bootstrap,config,database,public,resources,routes,storage,vendor}/**"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_KEY": "base64:9eJ4n8hP8L7M0HkI8LwE1E7F2T3W2T3W2T3W2T3W2T3=",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_STORE": "array",
        "QUEUE_CONNECTION": "sync",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "sqlite",
        "BROADCAST_CONNECTION": "reverb",
        "REVERB_APP_ID": "794711",
        "REVERB_APP_KEY": "my-reverb-key",
        "REVERB_APP_SECRET": "my-reverb-secret",
        "REVERB_HOST": "127.0.0.1",
        "REVERB_PORT": "8080",
        "REVERB_SCHEME": "http"
    }
}